# Load Ledger V5 — .gitignore
# Purpose: keep secrets and build junk out of git. Real secrets live as
# Cloudflare Worker secrets (dashboard / wrangler secret put), never here.

# ---- Secrets & local env (NEVER commit) ----
.env
.env.*
!.env.example
.dev.vars
.dev.vars.*
.envrc
secrets.json
secrets.js
secrets.txt
credentials
credentials.json
service-account*.json
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*

# ---- Cloudflare / Wrangler ----
.wrangler/
wrangler.toml.bak
.mf/

# ---- Node ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Vite build output ----
dist/
dist-ssr/
*.local

# ---- Editor / OS cruft ----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
